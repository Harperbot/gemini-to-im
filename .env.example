TELEGRAM_BOT_TOKEN=您的_TELEGRAM_BOT_TOKEN
GEMINI_API_KEY=您的_GEMINI_API_KEY

# Security: Comma-separated list of allowed Telegram User IDs
# Message @userinfobot to get your ID
ALLOWED_USER_IDS=7834785896

# Enable localized tools (Currently supports: TW)
TDX_CLIENT_ID=your_tdx_client_id_here
TDX_CLIENT_SECRET=your_tdx_client_secret_here

# Optional: For Surf Spot Query Tool (台灣衝浪查詢)
CWA_API_KEY=your_cwa_api_key_here
